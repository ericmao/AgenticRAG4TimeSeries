# Copy to .env and fill in; never commit .env
OPENAI_API_KEY=
OPENCTI_URL=
OPENCTI_TOKEN=
KB_PATH=kb/
# MVP Investigation SPA（Vite，建置 packages/mvp-investigation-spa 前設定）：完整頁頂部「在 SenseL 開啟」連結
# VITE_SENSEL_ORIGIN=http://localhost:3000

# MVP UI：off | merge | db_only（非 off 時需 DATABASE_URL；寫入 API 建議設 MVP_UI_API_KEY）
KB_DB_MODE=off
# /kb 的 llm_file_summary／llm_summary 僅來自 outputs/.kb_*_llm_cache.json（瀏覽時不呼叫 LLM）
RUN_MODE=dry_run
PROMPT_VERSION=v0.1

# Layer B inference (optional)
# API 根網址 only：例如 https://cti.ericmao.dev（勿用 /dashboard/... 或 #ioc 等瀏覽器路徑；程式會 POST 至 {BASE}/api/v1/...）
CONTROL_PLANE_BASE_URL=
# Bearer 金鑰（Authorization: Bearer …）；須與 CP 後端設定的 token 一致。非 Docker 映像名 layerc-demo；本機範例可見 deployments/docker/README_LAYER_C（常用 demo）
CONTROL_PLANE_TOKEN=
TENANT_ID=tenant-default
GPU_MODE=off
MODEL_DEVICE=auto

# LLM for Layer C optional analysis (default: local Ollama)
LLM_BACKEND=ollama
# 本機直跑用 127.0.0.1；Docker 內請用 http://host.docker.internal:11434（見 docker-compose.local.yml）
LLM_OLLAMA_PRIMARY=http://127.0.0.1:11434
LLM_MODEL=llama3:latest
LLM_TIMEOUT=120
LLM_TEMPERATURE=0.1

# Layer C optional: time-series signals and LLM analysis
USE_TIME_SERIES_SIGNALS=false
USE_LANGCHAIN_FOR_ANALYSIS=false

# Wazuh Indexer（OpenSearch）— mvp_wazuh_episode_pg.py / UI「啟動 Wazuh 分析」必備；URL 為 Indexer API 根（通常 :9200），非 Dashboard
# 複製本檔為 .env 後填入；docker compose 會讀取 .env 帶入 mvp_ui 容器
# 遠端 rsync 部署預設不同步 .env，可參考 deployments/dotenv.wazuh.example 在伺服器上建立。
WAZUH_INDEXER_URL=https://127.0.0.1:9200
WAZUH_INDEXER_USERNAME=admin
WAZUH_INDEXER_PASSWORD=
WAZUH_VERIFY_SSL=0
